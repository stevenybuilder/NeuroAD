# Cloud Build upload allowlist-by-exclusion. When a .gcloudignore exists, gcloud
# uses ONLY this file (it does NOT fall back to .gitignore), so every sensitive
# path must be named here explicitly.
#
# NOTE: this governs ONLY what is uploaded to Cloud Build (which builds the PRIVATE
# Cloud Run image) — it is NOT .gitignore and has no bearing on the public GitHub
# repo (that is governed by .gitignore, which excludes _manifests/ + _gated/). The
# combined backend build (Dockerfile.combined) ships the main engine AND the SFG
# imaging backend (mri_visualizations/) with its de-identified real cohort, so
# mri_visualizations/ is UPLOADED here — except its local venv/caches/weights,
# which are excluded below. Nothing with a PTID/IMAGEUID or gated weights uploads.

# --- secrets / credentials (never upload) ---
.env
.env.*
*.key
*.pem
*token*
*secret*

# --- gated NeuroJEPA weights + raw embedding dumps (never upload) ---
*.safetensors
*.pt
*.pth
*.ckpt
*embeddings*.csv
*_emb.csv
*.npy
*.mgz
# gated volumes live under data/ (excluded below); app/scans/*.nii.gz are the
# public MNI152 template + demo ROI masks and ARE served by the demo image.
data/**/*.nii
data/**/*.nii.gz
# Dockerfile.backend COPYs data/registry.yaml + data/real/ (public OASIS tables +
# manifests). Keep gated / NeuroJEPA-derived / stub data OUT: embeddings already
# match *embeddings*.csv above; also exclude the gated ADNI table, the PCA fixture,
# the stub CSVs, and the empty raw/processed trees.
data/raw/
data/processed/
data/real/_gated/APOERES*.csv
data/real/_stubs/
data/real/fixtures/
# ADNI ingestion manifests carry DUA-protected subject/image identifiers
# (PTID/RID/IMAGEUID) + per-subject biomarkers. Not needed to serve the demo
# (server.py/src never read them). NEVER ship them in the image.
data/real/_manifests/

# --- ADNI live-investigate compute tables: SHIP to the private Cloud Run image so
# /api/investigate runs ADNI live (the deploy is not published; only computed cards
# are served over HTTP, never raw rows). These tables are DE-IDENTIFIED — anonymized
# integer subject_id, ZERO PTIDs / IMAGEUIDs (verified) — and stay gitignored (never
# on public GitHub). These negations override the *embeddings*.csv + _gated rules above.
!data/real/_gated/adni.csv
!data/real/_gated/adni_roi.csv
!data/real/adni_neurojepa_embeddings.csv
!data/real/adni_conversion_neurojepa_embeddings.csv
# Open-cohort Neuro-JEPA embeddings so oasis:neurojepa / openbhb:neurojepa also run
# live. OASIS = public OAS* IDs, OpenBHB = anonymized integer IDs (no gated IDs,
# verified). Openly licensed vs ADNI's DUA; stay gitignored (never on public GitHub).
!data/real/oasis1_neurojepa_embeddings.csv
!data/real/oasis2_neurojepa_embeddings.csv
!data/real/openbhb_neurojepa_embeddings.csv

# --- everything not needed to serve the static demo ---
.git/
.github/
.venv/
__pycache__/
**/__pycache__/
*.pyc
tests/
scripts/
notebooks/
reports/
docs/
design/
audit/
scratch/
skills/
app/build_demo_data.py
app/README.md
.pytest_cache/
.DS_Store
Makefile
*.egg-info/

# --- SFG imaging backend (mri_visualizations/): ship code + de-identified cohort,
# but NEVER the local virtualenv (~900 MB of Mac binaries), the derived caches are
# small and prewarm the viewer so they DO ship. SynthStrip weights (*.pt) already
# excluded globally above. No PTID crosswalk lives under mri_visualizations/.
mri_visualizations/.venv-sfg/
mri_visualizations/**/__pycache__/
mri_visualizations/backend/.pytest_cache/

# Uploaded to Cloud Build (combined backend): the Dockerfiles, src/, app/, policy/,
# data/registry.yaml, the de-identified data/real/ compute tables, and the SFG
# backend under mri_visualizations/ (code + adni/ixi/fixtures scans + prewarmed
# .cache). Excluded: secrets, gated weights, *embeddings*.csv (except negated),
# _manifests/, and the mri_visualizations venv.
