.venv/
__pycache__/
*.pyc
.pytest_cache/
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
reports/*.html
reports/*.pdf
.DS_Store
.env
*.egg-info/
build/
dist/

# --- NeuroJEPA compliance: never commit weights, volumes, or raw embedding dumps ---
# Weights are gated CC-BY-NC-ND (non-derivative); keep them out of git entirely.
*.safetensors
*.pt
*.pth
*.ckpt
*.nii
*.nii.gz
*.mgz
# Derived NeuroJEPA embedding tables: keep LOCAL only. Redistributing a large
# table of embeddings could be argued a derivative of the CC-BY-NC-ND weights.
# Result numbers (AUCs) in reports/ are fine to commit; the raw vectors are not.
*embeddings*.csv
*_emb.csv
*.npy
*.nii
*.nii.gz
.env
.env.*
!.env.example

# ultracode pipeline working notes (local only)
scratch/

# --- gated cohort data: assembled real ADNI/OASIS-3/NACC contract tables ---
# These carry subject-level gated data (age/sex/dx/biomarkers/FreeSurfer per RID)
# under a Data Use Agreement — NEVER commit or redistribute. The demo ships only
# aggregate numbers baked into app/demo_data.json; the raw table stays local.
data/real/_gated/

# NeuroJEPA-derived tables (embeddings & PCA projections): local-only, never GitHub.
# The name-based *embeddings*.csv rule missed the pca10 fixture; this catches all.
*neurojepa*.csv
data/real/fixtures/
