# Copy to .env and fill in YOUR OWN tokens. .env is git-ignored — never commit real values.

# Gated Neuro-JEPA access (fine-grained, read-only). Request at:
#   https://huggingface.co/NYUMedML/Neuro-JEPA
# Only needed to (re)generate real Neuro-JEPA embeddings; the referee runs without it.
HF_TOKEN=

# Claude API key for the live adjudicator layer (courtroom / reviewer / narrator).
# The engine falls back to deterministic templates when this is unset.
ANTHROPIC_API_KEY=
