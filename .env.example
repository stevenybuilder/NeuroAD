# Copy to .env and fill in YOUR OWN tokens. .env is git-ignored — never commit real values.

# Gated Neuro-JEPA access (fine-grained, read-only). Request at:
#   https://huggingface.co/NYUMedML/Neuro-JEPA
# Only needed to (re)generate real Neuro-JEPA embeddings; the referee runs without it.
HF_TOKEN=

# Claude API key for the live adjudicator layer (courtroom / reviewer / narrator).
# The engine falls back to deterministic templates when this is unset.
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Translation-layer adapters (src/neuroad/integrations). ALL are OPTIONAL — the
# adapters run fully offline with deterministic, provenance-labeled fallbacks.
# These only switch on the LIVE paths.
# ---------------------------------------------------------------------------

# AlphaFold — EBI AlphaFold DB is keyless; override only to pin a mirror/version.
# AF_DB_BASE_URL=https://alphafold.ebi.ac.uk/api

# PI4AD — live priority-index portal. Unset uses the bundled snapshot.
# PI4AD_PORTAL_URL=http://www.genetictargets.com/PI4AD/ad

# Multimodal transformer (vkola-lab/ncomms2025). Needs the [fusion] extra
# (torch, monai, adrd) AND the gated checkpoint. Unset -> logistic surrogate.
# NCOMMS2025_REPO=/path/to/vkola-lab/ncomms2025
# NCOMMS2025_CKPT=/path/to/model_stage_1.ckpt

# GNN/LLM repurposing — live TxGNN. Needs the [gnn] extra + a checkpoint.
# Unset -> curated repurposing snapshot.
# NEUROAD_ENABLE_TXGNN=1
# TXGNN_CKPT_DIR=/path/to/txgnn_checkpoint
