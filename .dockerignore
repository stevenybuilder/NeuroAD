# Keep the backend image lean AND free of gated/licensed/secret data.
# (The static ./Dockerfile only COPYs nginx.conf + app/index.html + app/demo_data.json,
#  none of which are excluded here, so it is unaffected.)

# Never ship gated / non-commercial-licensed data into a deployable image...
data/real/_gated/
data/real/_stubs/
data/real/fixtures/
data/real/_manifests/
*neurojepa*.csv
data/raw/
data/processed/
# ...EXCEPT the de-identified ADNI compute tables (anonymized integer subject_id,
# ZERO PTIDs — verified). These ship so /api/investigate runs ADNI live; they stay
# gitignored (never on public GitHub). Negations override the rules just above.
!data/real/_gated/adni.csv
!data/real/_gated/adni_roi.csv
!data/real/adni_neurojepa_embeddings.csv
!data/real/adni_conversion_neurojepa_embeddings.csv
# Open-cohort Neuro-JEPA embeddings (OASIS = public OAS* IDs, OpenBHB = anonymized
# integer IDs; no gated identifiers). Ship so oasis:neurojepa / openbhb:neurojepa
# run live too. Openly licensed (unlike ADNI's DUA); stay gitignored regardless.
!data/real/oasis1_neurojepa_embeddings.csv
!data/real/oasis2_neurojepa_embeddings.csv
!data/real/openbhb_neurojepa_embeddings.csv

# Secrets / local env
.env
.env.*

# Build + VCS + caches
.venv/
.git/
.gitignore
**/__pycache__/
**/*.pyc
.pytest_cache/
*.egg-info/

# Local scratch / bulky non-runtime artifacts
scratch/
Archive/
download/
download*/
notebooks/
docs/
reports/
*.pdf
.DS_Store
